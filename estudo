SELECT
    Pag_DataPagto,          
    Pag_Valor,             
    FkBanco                 
FROM Pagar, Banco
WHERE FkBanco = IdBanco
  AND Pag_DataPagto IS NOT NULL
  AND MONTH(Pag_DataPagto) = 2
  AND YEAR(Pag_DataPagto) = 2019


