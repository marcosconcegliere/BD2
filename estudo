(
select * from receber
where FkBanco = IdBanco
)
 

select IdBanco, Ban_Descricao, count(*) as qtd_faturas, sum(Pag_Valor) as valor_total from banco, Pagar
WHERE FkBanco = IdBanco
group by Ban_Descricao, IdBanco
order by valor_total


