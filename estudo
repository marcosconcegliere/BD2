SELECT 
    b.Ban_Descricao, 
    p.IdPagar, 
    p.Pag_Valor
FROM 
    banco b 
JOIN 
    Pagar p ON b.IdBanco = p.FkBanco
WHERE 
    p.Pag_Valor > (
        SELECT AVG(p2.Pag_Valor) 
        FROM Pagar p2
        WHERE p2.FkBanco = b.IdBanco
    );


select e.Idempresa, 
       e.Emp_RazaoSocial as nome_empresa, 
       sum (r.rec_valor) as total_recebido,
       count(r.idreceber) as qtdFaturas,
       CASE 
            WHEN sum (r.rec_valor) >= 10000 then 'Cliente Ouro'
            WHEN sum (r.rec_valor) >= 5000 then 'Cliente Prata'
            WHEN sum (r.rec_valor) >= 1000 then 'Cliente Bronze'
            else 'Cliente eventual'
            end as classificacao
from empresa e
JOIN receber r on e.Idempresa = r.fkempresa
group by e.Idempresa, e.Emp_RazaoSocial

