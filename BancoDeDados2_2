select * from banco*/

/*5*/

select * into total_backup from
(select Ban_Descricao,
 sum(Pag_Valor) as total,
 sum(1) as qtd
from
pagar, banco
where fkbanco = idbanco
and pag_datapagto is not null
group by
 ban_descricao
having sum(pag_valor) > 1000)as tt

