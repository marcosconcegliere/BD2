/*5*/

select Emp_RazaoSocial, 
Pag_Fatura, 
pag_DataVencimento, 
DATEDIFF(dd, Pag_DataVencimento, getdate()) as dias_atraso
from empresa, pagar
where Fkempresa = Idempresa and pag_datapagto is null

