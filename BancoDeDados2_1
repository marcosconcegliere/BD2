/**/

select 'Pagar' as tipo,
sum(Pag_valor) as total_dia, 
Pag_DataVencimento as vencimento,
datename(dw, Pag_DataVencimento)
from Pagar
where Pag_DataPagto is not null

group by Pag_DataVencimento, 
datename(dw, Pag_DataVencimento)

union all

select 'receber' as tipo, 
sum(rec_valor) as total_dia, 
rec_vencimento as vencimento,
datename(dw, rec_vencimento)
from receber
group by rec_vencimento,
datename(dw, rec_vencimento)
order by Pag_DataVencimento

